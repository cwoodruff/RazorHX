@page
@model IndexModel
@{
    Layout = "_DocsLayout";
    ViewData["Title"] = "htmxRazor";
    ViewData["HideSidebar"] = true;
}

<!-- Hero -->
<section class="docs-hero">
    <h1 class="docs-hero__title">htmxRazor</h1>
    <p class="docs-hero__subtitle">
        Server-rendered UI components for ASP.NET Core with first-class htmx integration.
    </p>
    <div class="docs-hero__actions">
        <rhx-button rhx-variant="brand" rhx-size="large" rhx-href="/Docs/GettingStarted">
            Get Started
        </rhx-button>
        <rhx-button rhx-variant="neutral" rhx-appearance="outlined" rhx-size="large"
                    rhx-href="https://github.com/cwoodruff/htmxRazor" rhx-target="_blank">
            View on GitHub
        </rhx-button>
    </div>
</section>

<rhx-divider />

<!-- Features -->
<section class="docs-features">
    <div class="docs-feature-card">
        <rhx-icon rhx-name="grid" rhx-size="32" />
        <h3>Tag Helper Components</h3>
        <p>80+ server-rendered components across 11 categories. Buttons, forms, data tables, navigation, overlays, feedback, and more.</p>
    </div>
    <div class="docs-feature-card">
        <rhx-icon rhx-name="refresh" rhx-size="32" />
        <h3>htmx Integration</h3>
        <p>Every component supports hx-get, hx-post, hx-target, hx-swap, and all htmx attributes natively.</p>
    </div>
    <div class="docs-feature-card">
        <rhx-icon rhx-name="palette" rhx-size="32" />
        <h3>Design Tokens</h3>
        <p>Light and dark themes via CSS custom properties. Toggle with a single attribute or JavaScript call.</p>
    </div>
</section>

<rhx-divider />

<!-- What's New in v1.4 -->
<section style="max-width: 900px; margin: 0 auto; padding: var(--rhx-space-2xl) var(--rhx-space-xl);">
    <h2 style="text-align: center; font-size: var(--rhx-font-size-2xl); font-weight: var(--rhx-font-weight-bold); margin-bottom: var(--rhx-space-lg); color: var(--rhx-color-text);">
        What's New in v1.4
    </h2>
    <p style="text-align: center; color: var(--rhx-color-text-muted); margin-bottom: var(--rhx-space-xl);">
        Real-time streaming, multi-step wizards, and optimistic UI patterns.
    </p>

    <div class="docs-features">
        <div class="docs-feature-card">
            <rhx-icon rhx-name="cast" rhx-size="28" />
            <h3>SSE Stream</h3>
            <p>Declarative Server-Sent Events via <code>&lt;rhx-sse-stream&gt;</code>. Companion server-side helpers format <code>IAsyncEnumerable&lt;string&gt;</code> as <code>text/event-stream</code>.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/SseStream">View docs</rhx-button>
        </div>
        <div class="docs-feature-card">
            <rhx-icon rhx-name="list" rhx-size="28" />
            <h3>Multi-step Wizard</h3>
            <p>Visual stepper indicator with <code>&lt;rhx-wizard&gt;</code> and <code>&lt;rhx-wizard-step&gt;</code>. Auto-generated navigation buttons and server-side state tracking.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/Wizard">View docs</rhx-button>
        </div>
        <div class="docs-feature-card">
            <rhx-icon rhx-name="edit" rhx-size="28" />
            <h3>Response-Aware Form</h3>
            <p><code>&lt;rhx-htmx-form&gt;</code> auto-configures <code>hx-target-422</code> and <code>hx-target-5xx</code>. Built-in error container and submit-disable behavior.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/HtmxForm">View docs</rhx-button>
        </div>
        <div class="docs-feature-card">
            <rhx-icon rhx-name="git-commit" rhx-size="28" />
            <h3>Timeline</h3>
            <p>Vertical, horizontal, and alternating timelines with <code>&lt;rhx-timeline&gt;</code>. Variant-colored connectors, labels, and icon slots for audit logs and activity feeds.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/Timeline">View docs</rhx-button>
        </div>
        <div class="docs-feature-card">
            <rhx-icon rhx-name="zap" rhx-size="28" />
            <h3>Optimistic UI</h3>
            <p>Add <code>rhx-optimistic</code> to switches, ratings, and buttons. Visual state updates instantly on click; reverts automatically on server error.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/Optimistic">View docs</rhx-button>
        </div>
        <div class="docs-feature-card">
            <rhx-icon rhx-name="plus-circle" rhx-size="28" />
            <h3>Load More</h3>
            <p>Button-triggered pagination with <code>&lt;rhx-load-more&gt;</code>. A simpler alternative to infinite scroll for content feeds and lists.</p>
            <rhx-button rhx-variant="brand" rhx-appearance="plain" rhx-size="small" rhx-href="/Docs/Components/LoadMore">View docs</rhx-button>
        </div>
    </div>
</section>

<rhx-divider />

<!-- Quick Start -->
<section class="docs-quickstart">
    <h2>Quick Start</h2>

    <div class="docs-quickstart__step">
        <h3>1. Install the package</h3>
        <div class="docs-code">
            <pre><code>dotnet add package htmxRazor</code></pre>
        </div>
    </div>

    <div class="docs-quickstart__step">
        <h3>2. Configure in Program.cs</h3>
        <div class="docs-code">
            <pre><code>builder.Services.AddhtmxRazor();

var app = builder.Build();
app.UsehtmxRazor();
app.MapRazorPages();</code></pre>
        </div>
    </div>

    <div class="docs-quickstart__step">
        <h3>3. Register Tag Helpers</h3>
        <div class="docs-code">
            <pre><code>@@addTagHelper *, htmxRazor</code></pre>
        </div>
    </div>

    <div class="docs-quickstart__step">
        <h3>4. Use a component</h3>
        <div class="docs-code">
            <pre><code>&lt;rhx-button rhx-variant="brand" hx-get="/api/data" hx-target="#result"&gt;
    Load Data
&lt;/rhx-button&gt;</code></pre>
        </div>
    </div>
</section>

<rhx-divider />

<!-- Example App -->
<section style="max-width: 700px; margin: 0 auto; padding: var(--rhx-space-2xl) var(--rhx-space-xl);">
    <rhx-callout rhx-variant="brand" rhx-icon="check-circle">
        <strong>See it in action</strong> — The
        <a href="https://github.com/cwoodruff/htmxRazor/tree/main/htmxRazor.Example"
           style="color: var(--rhx-color-brand-600); text-decoration: underline;">
            htmxRazor.Example</a>
        project is a complete To-Do app built with htmxRazor. It demonstrates real-world usage
        of buttons, inputs, dialogs, tabs, badges, tooltips, and htmx-powered interactions
        — all in under 200 lines of Razor markup.
        <div style="margin-top: var(--rhx-space-md);">
            <rhx-button rhx-variant="brand" rhx-appearance="outlined" rhx-size="small"
                        rhx-href="https://github.com/cwoodruff/htmxRazor/tree/main/htmxRazor.Example"
                        rhx-target="_blank">
                <rhx-icon rhx-name="external-link" rhx-size="16" />
                View Example on GitHub
            </rhx-button>
        </div>
    </rhx-callout>
</section>

<rhx-divider />

<!-- Component Categories -->
<section style="padding: var(--rhx-space-2xl) var(--rhx-space-xl);">
    <h2 style="text-align: center; font-size: var(--rhx-font-size-2xl); font-weight: var(--rhx-font-weight-bold); margin-bottom: var(--rhx-space-xl); color: var(--rhx-color-text);">
        Component Categories
    </h2>

    <div class="docs-category-grid">
        @foreach (var cat in Model.Categories)
        {
            <a href="@cat.Href" class="docs-category-card">
                <rhx-card>
                    <div style="text-align: center; padding: var(--rhx-space-md);">
                        <rhx-icon rhx-name="@cat.Icon" rhx-size="24" />
                        <h3 style="font-size: var(--rhx-font-size-md); margin: var(--rhx-space-sm) 0 var(--rhx-space-xs);">@cat.Name</h3>
                        <rhx-badge rhx-variant="neutral">@cat.Count components</rhx-badge>
                    </div>
                </rhx-card>
            </a>
        }
    </div>
</section>
