@page
@model CommandPaletteModel
@{
    Layout = "_ComponentPage";
    ViewData["Title"] = "Command Palette";
    ViewData["ComponentName"] = "Command Palette";
    ViewData["ComponentTag"] = "rhx-command-palette";
    ViewData["ComponentDescription"] = "A modal search overlay activated via Cmd+K with server-rendered results, keyboard navigation, and htmx integration.";
}

<section class="docs-component-section">
    <h2>Examples</h2>

    <!-- Basic (static results) -->
    <div class="docs-example">
        <h3>Basic (Static Results)</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="basic-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="basic-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="basic-preview" rhx-active="true">
                <div class="docs-preview docs-preview--vertical">
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                onclick="var cp = document.getElementById('basic-cp'); cp.removeAttribute('hidden'); cp.querySelector('input').focus();">
                        Open Palette
                    </rhx-button>

                    <rhx-command-palette id="basic-cp" rhx-label="Quick search">
                        <rhx-command-group rhx-heading="Pages">
                            <rhx-command-item rhx-value="home" rhx-href="/" rhx-icon="home">
                                Home
                            </rhx-command-item>
                            <rhx-command-item rhx-value="getting-started" rhx-href="/Docs/GettingStarted" rhx-icon="file">
                                Getting Started
                            </rhx-command-item>
                        </rhx-command-group>
                        <rhx-command-group rhx-heading="Components">
                            <rhx-command-item rhx-value="button" rhx-href="/Docs/Components/Button" rhx-icon="cursor"
                                              rhx-description="Interactive click target">
                                Button
                            </rhx-command-item>
                            <rhx-command-item rhx-value="dialog" rhx-href="/Docs/Components/Dialog" rhx-icon="layers"
                                              rhx-description="Modal dialog overlay">
                                Dialog
                            </rhx-command-item>
                            <rhx-command-item rhx-value="data-table" rhx-href="/Docs/Components/DataTable" rhx-icon="table"
                                              rhx-description="Server-driven data table">
                                Data Table
                            </rhx-command-item>
                        </rhx-command-group>
                    </rhx-command-palette>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="basic-code">
                <div class="docs-code">
                    <pre><code>@Model.BasicCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- Item variations -->
    <div class="docs-example">
        <h3>Item Variations (Icons, Descriptions, Shortcuts, Disabled)</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="items-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="items-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="items-preview" rhx-active="true">
                <div class="docs-preview docs-preview--vertical">
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                onclick="var cp = document.getElementById('items-cp'); cp.removeAttribute('hidden'); cp.querySelector('input').focus();">
                        Open Palette with Item Variations
                    </rhx-button>

                    <rhx-command-palette id="items-cp" rhx-label="Item variations" rhx-placeholder="Try navigating with arrow keys...">
                        <rhx-command-group rhx-heading="Settings">
                            <rhx-command-item rhx-value="settings" rhx-href="/Docs/Components/CommandPalette"
                                             rhx-icon="settings" rhx-description="Manage your preferences" rhx-shortcut="&#8984;,">
                                Settings
                            </rhx-command-item>
                            <rhx-command-item rhx-value="profile" rhx-href="/Docs/Components/CommandPalette"
                                             rhx-icon="user" rhx-description="View your profile">
                                Profile
                            </rhx-command-item>
                        </rhx-command-group>
                        <rhx-command-group rhx-heading="Other">
                            <rhx-command-item rhx-value="home" rhx-href="/" rhx-icon="home">
                                Home
                            </rhx-command-item>
                            <rhx-command-item rhx-value="locked" rhx-disabled="true" rhx-icon="lock">
                                Locked Feature
                            </rhx-command-item>
                        </rhx-command-group>
                    </rhx-command-palette>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="items-code">
                <div class="docs-code">
                    <pre><code>@Model.ItemCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- htmx Integration -->
    <div class="docs-example">
        <h3>htmx Integration (Server Search)</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="htmx-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="htmx-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="htmx-preview" rhx-active="true">
                <div class="docs-preview docs-preview--vertical">
                    <p style="color: var(--rhx-color-text-muted); font-size: var(--rhx-font-size-sm);">
                        Press <kbd style="font-family: var(--rhx-font-family-mono, monospace); font-size: var(--rhx-font-size-xs); padding: 2px 6px; border: var(--rhx-border-width) solid var(--rhx-color-border); border-radius: var(--rhx-radius-sm);">&#8984;K</kbd> /
                        <kbd style="font-family: var(--rhx-font-family-mono, monospace); font-size: var(--rhx-font-size-xs); padding: 2px 6px; border: var(--rhx-border-width) solid var(--rhx-color-border); border-radius: var(--rhx-radius-sm);">Ctrl+K</kbd>
                        to open, or click the button below.
                    </p>
                    <rhx-button rhx-variant="brand" rhx-appearance="outlined"
                                onclick="var cp = document.getElementById('htmx-cp'); cp.removeAttribute('hidden'); cp.querySelector('input').focus();">
                        <rhx-icon name="search" rhx-size="small"></rhx-icon>
                        Search Components...
                    </rhx-button>

                    <rhx-command-palette id="htmx-cp"
                        rhx-placeholder="Search components..."
                        hx-get="/Docs/Components/CommandPalette?handler=Search"
                        rhx-debounce="200"
                        rhx-label="Search components">
                    </rhx-command-palette>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="htmx-code">
                <div class="docs-code">
                    <pre><code>@Model.HtmxCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>
</section>

<!-- Properties -->
@await Html.PartialAsync("_PropertyTable", Model.Properties)

<section class="docs-component-section">
    <h2>Group Properties</h2>
    <p style="margin-bottom: var(--rhx-space-md); color: var(--rhx-color-text-muted);">
        Properties for <code>&lt;rhx-command-group&gt;</code> elements.
    </p>
    @await Html.PartialAsync("_PropertyTable", Model.GroupProperties)
</section>

<section class="docs-component-section">
    <h2>Item Properties</h2>
    <p style="margin-bottom: var(--rhx-space-md); color: var(--rhx-color-text-muted);">
        Properties for <code>&lt;rhx-command-item&gt;</code> elements.
    </p>
    @await Html.PartialAsync("_PropertyTable", Model.ItemProperties)
</section>

<section class="docs-component-section">
    <h2>Accessibility</h2>
    <ul class="docs-a11y-list">
        <li>The palette uses <code>role="dialog"</code> with <code>aria-modal="true"</code> for screen reader announcement.</li>
        <li>The search input uses <code>role="combobox"</code> with <code>aria-expanded</code> and <code>aria-autocomplete="list"</code>.</li>
        <li>Results use <code>role="listbox"</code> with items as <code>role="option"</code>.</li>
        <li>Keyboard: <kbd>&#8984;K</kbd> / <kbd>Ctrl+K</kbd> opens; <kbd>Escape</kbd> closes; Arrow keys navigate; <kbd>Enter</kbd> selects.</li>
        <li>Groups use <code>role="group"</code> with <code>aria-labelledby</code> referencing the heading.</li>
        <li>Disabled items have <code>aria-disabled="true"</code> and are skipped during keyboard navigation.</li>
    </ul>
</section>
