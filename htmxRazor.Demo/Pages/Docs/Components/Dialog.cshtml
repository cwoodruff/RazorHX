@page
@model DialogModel
@{
    Layout = "_ComponentPage";
    ViewData["Title"] = "Dialog";
    ViewData["ComponentName"] = "Dialog";
    ViewData["ComponentTag"] = "rhx-dialog";
    ViewData["ComponentDescription"] = "A modal dialog using the native HTML dialog element with focus trap, ESC to close, and htmx integration.";
}

<section class="docs-component-section">
    <h2>Examples</h2>

    <!-- Basic Dialog -->
    <div class="docs-example">
        <h3>Basic Dialog</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="basic-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="basic-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="basic-preview" rhx-active="true">
                <div class="docs-preview">
                    <rhx-button rhx-variant="brand" data-rhx-dialog-open="demo-dialog">
                        Open Dialog
                    </rhx-button>

                    <rhx-dialog id="demo-dialog" rhx-label="Example Dialog">
                        <p>This is a basic dialog with a title and close button.</p>
                        <p>Press ESC or click the close button to dismiss.</p>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="basic-code">
                <div class="docs-code">
                    <pre><code>@Model.BasicCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- No Header -->
    <div class="docs-example">
        <h3>No Header</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="noheader-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="noheader-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="noheader-preview" rhx-active="true">
                <div class="docs-preview">
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined" data-rhx-dialog-open="noheader-dialog">
                        Open Headerless Dialog
                    </rhx-button>

                    <rhx-dialog id="noheader-dialog" rhx-no-header="true">
                        <div style="text-align: center; padding: var(--rhx-space-xl);">
                            <p style="font-size: var(--rhx-font-size-lg); margin-bottom: var(--rhx-space-md);">
                                Are you sure you want to proceed?
                            </p>
                            <div style="display: flex; gap: var(--rhx-space-md); justify-content: center;">
                                <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                            onclick="this.closest('dialog').close()">Cancel</rhx-button>
                                <rhx-button rhx-variant="brand"
                                            onclick="this.closest('dialog').close()">Confirm</rhx-button>
                            </div>
                        </div>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="noheader-code">
                <div class="docs-code">
                    <pre><code>@Model.NoHeaderCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- With Footer -->
    <div class="docs-example">
        <h3>With Footer</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="footer-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="footer-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="footer-preview" rhx-active="true">
                <div class="docs-preview">
                    <rhx-button rhx-variant="brand" data-rhx-dialog-open="footer-dialog">
                        Open Dialog with Footer
                    </rhx-button>

                    <rhx-dialog id="footer-dialog" rhx-label="Edit Profile">
                        <rhx-input rhx-label="Display Name" rhx-placeholder="Enter name" name="displayName" />
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                        onclick="this.closest('dialog').close()">Cancel</rhx-button>
                            <rhx-button rhx-variant="brand"
                                        onclick="this.closest('dialog').close()">Save Changes</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="footer-code">
                <div class="docs-code">
                    <pre><code>@Model.FooterCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- Size Variants -->
    <div class="docs-example">
        <h3>Size Variants</h3>
        <p>Use <code>rhx-size</code> to control the dialog width. Preset values: <code>small</code>, <code>medium</code>, <code>large</code>, <code>full</code>.</p>
        <rhx-tab-group>
            <rhx-tab rhx-panel="size-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="size-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="size-preview" rhx-active="true">
                <div class="docs-preview" style="display: flex; gap: var(--rhx-space-md); flex-wrap: wrap;">
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined" rhx-size="small"
                                data-rhx-dialog-open="size-sm-dialog">Small</rhx-button>
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined" rhx-size="small"
                                data-rhx-dialog-open="size-md-dialog">Medium</rhx-button>
                    <rhx-button rhx-variant="brand" rhx-size="small"
                                data-rhx-dialog-open="size-lg-dialog">Large</rhx-button>
                    <rhx-button rhx-variant="neutral" rhx-appearance="outlined" rhx-size="small"
                                data-rhx-dialog-open="size-full-dialog">Full</rhx-button>

                    <rhx-dialog id="size-sm-dialog" rhx-label="Small Dialog" rhx-size="small">
                        <p>A compact dialog at <strong>24rem</strong> wide. Good for confirmations and short messages.</p>
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="brand" rhx-size="small"
                                        onclick="this.closest('dialog').close()">Got it</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>

                    <rhx-dialog id="size-md-dialog" rhx-label="Medium Dialog" rhx-size="medium">
                        <p>The medium size at <strong>32rem</strong> wide. Works well for simple forms with a few fields.</p>
                        <rhx-input rhx-label="Name" rhx-placeholder="Enter your name" name="demo-name" />
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                        onclick="this.closest('dialog').close()">Cancel</rhx-button>
                            <rhx-button rhx-variant="brand"
                                        onclick="this.closest('dialog').close()">Save</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>

                    <rhx-dialog id="size-lg-dialog" rhx-label="Large Dialog" rhx-size="large">
                        <p>A wide dialog at <strong>48rem</strong>. Ideal for multi-column forms, data tables, or detailed content.</p>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--rhx-space-md); margin-top: var(--rhx-space-md);">
                            <rhx-input rhx-label="First Name" rhx-placeholder="Jane" name="demo-first" />
                            <rhx-input rhx-label="Last Name" rhx-placeholder="Smith" name="demo-last" />
                            <rhx-input rhx-label="Email" rhx-placeholder="jane@example.com" name="demo-email" type="email" />
                            <rhx-input rhx-label="Phone" rhx-placeholder="+1 555-1234" name="demo-phone" type="tel" />
                        </div>
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="neutral" rhx-appearance="outlined"
                                        onclick="this.closest('dialog').close()">Cancel</rhx-button>
                            <rhx-button rhx-variant="brand"
                                        onclick="this.closest('dialog').close()">Save Profile</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>

                    <rhx-dialog id="size-full-dialog" rhx-label="Full-Width Dialog" rhx-size="full">
                        <p>Full-width dialog at <strong>90vw</strong>. Useful for complex workflows, dashboards, or image previews.</p>
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="brand"
                                        onclick="this.closest('dialog').close()">Close</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="size-code">
                <div class="docs-code">
                    <pre><code>@Model.SizeCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- Custom Width -->
    <div class="docs-example">
        <h3>Custom Width</h3>
        <p>Pass any CSS width value to <code>rhx-size</code> for a custom dialog width.</p>
        <rhx-tab-group>
            <rhx-tab rhx-panel="custom-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="custom-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="custom-preview" rhx-active="true">
                <div class="docs-preview" style="display: flex; gap: var(--rhx-space-md); flex-wrap: wrap;">
                    <rhx-button rhx-variant="brand" rhx-appearance="outlined"
                                data-rhx-dialog-open="custom-width-dialog">
                        Open 40rem Dialog
                    </rhx-button>

                    <rhx-dialog id="custom-width-dialog" rhx-label="Custom Width" rhx-size="40rem">
                        <p>This dialog uses a custom width of <strong>40rem</strong> set via <code>rhx-size="40rem"</code>.</p>
                        <p>You can use any CSS length: <code>600px</code>, <code>70vw</code>, <code>40rem</code>, etc.</p>
                        <rhx-dialog-footer>
                            <rhx-button rhx-variant="brand"
                                        onclick="this.closest('dialog').close()">Close</rhx-button>
                        </rhx-dialog-footer>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="custom-code">
                <div class="docs-code">
                    <pre><code>@Model.CustomWidthCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>

    <!-- htmx Integration -->
    <div class="docs-example">
        <h3>htmx Integration</h3>
        <rhx-tab-group>
            <rhx-tab rhx-panel="htmx-preview" rhx-active="true">Preview</rhx-tab>
            <rhx-tab rhx-panel="htmx-code">Code</rhx-tab>
            <rhx-tab-panel rhx-name="htmx-preview" rhx-active="true">
                <div class="docs-preview">
                    <rhx-button rhx-variant="brand"
                                hx-get="/Docs/Components/Dialog?handler=EditForm"
                                hx-target="#htmx-dialog .rhx-dialog__body"
                                data-rhx-dialog-open="htmx-dialog">
                        Edit Profile
                    </rhx-button>

                    <rhx-dialog id="htmx-dialog" rhx-label="Edit Profile">
                        <p style="color: var(--rhx-color-text-muted);">Loading...</p>
                    </rhx-dialog>
                </div>
            </rhx-tab-panel>
            <rhx-tab-panel rhx-name="htmx-code">
                <div class="docs-code">
                    <pre><code>@Model.HtmxCode</code></pre>
                </div>
            </rhx-tab-panel>
        </rhx-tab-group>
    </div>
</section>

<!-- Properties -->
@await Html.PartialAsync("_PropertyTable", Model.Properties)

<!-- Accessibility -->
<section class="docs-component-section">
    <h2>Accessibility</h2>
    <ul class="docs-a11y-list">
        <li>Uses the native <code>&lt;dialog&gt;</code> element with built-in focus trap and inert background.</li>
        <li>ESC key closes the dialog.</li>
        <li>Dialog title is linked via <code>aria-labelledby</code> for screen readers.</li>
        <li>Close button has <code>aria-label="Close"</code>.</li>
        <li>Focus is returned to the trigger element when the dialog closes.</li>
    </ul>
</section>
