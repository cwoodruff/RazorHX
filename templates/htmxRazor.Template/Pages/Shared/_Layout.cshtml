<!DOCTYPE html>
<html lang="en" data-rhx-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - htmxRazor App</title>
    @* htmxRazor core styles/scripts are auto-injected by htmxRazorTagHelperComponent *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav>
            <h1>htmxRazor App</h1>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <p>&copy; 2026 - htmxRazor</p>
    </footer>

    @Html.AntiForgeryToken()
    <script>
        document.addEventListener('htmx:configRequest', function(e) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) e.detail.headers['RequestVerificationToken'] = token.value;
        });
    </script>
    @* Include htmxRazor component scripts if needed *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
