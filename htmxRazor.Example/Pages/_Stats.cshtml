@model htmxRazor.Example.Pages.IndexModel

<div class="stats-row">
    <div class="stat-card stat-card--brand">
        <div class="stat-card__value">@Model.TotalCount</div>
        <div class="stat-card__label">Total Tasks</div>
    </div>
    <div class="stat-card stat-card--warning">
        <div class="stat-card__value">@Model.ActiveCount</div>
        <div class="stat-card__label">Active</div>
    </div>
    <div class="stat-card stat-card--success">
        <div class="stat-card__value">@Model.CompletedCount</div>
        <div class="stat-card__label">Completed</div>
    </div>
</div>

<!-- OOB: update tab badge counts -->
<span id="badge-all" hx-swap-oob="true">@Model.TotalCount</span>
<span id="badge-active" hx-swap-oob="true">@Model.ActiveCount</span>
<span id="badge-completed" hx-swap-oob="true">@Model.CompletedCount</span>
