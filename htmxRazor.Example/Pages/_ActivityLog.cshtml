@model List<htmxRazor.Example.Models.ActivityEntry>

@if (Model.Count == 0)
{
    <p style="text-align: center; color: var(--rhx-color-text-muted); padding: var(--rhx-space-lg);">No activity yet.</p>
}
else
{
    <rhx-timeline rhx-layout="vertical" rhx-align="start">
        @foreach (var entry in Model)
        {
            <rhx-timeline-item rhx-variant="@entry.Variant"
                               rhx-label="@entry.Timestamp.ToString("MMM d, h:mm tt")">
                <rhx-timeline-icon>
                    <rhx-icon rhx-name="@entry.Icon" rhx-size="16"></rhx-icon>
                </rhx-timeline-icon>
                @entry.Message
            </rhx-timeline-item>
        }
    </rhx-timeline>
}
